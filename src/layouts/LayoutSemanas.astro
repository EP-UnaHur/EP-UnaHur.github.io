---
import AsideMenu from '@components/AsideMenu.astro'
import DefaultLayout from './DefaultLayout.astro'

let semanas = await Astro.glob('../pages/cursada/**/*.md')

// Obtenemos la ruta actual para saber en qué comisión estamos
const currentPathname = Astro.url.pathname

// Filtramos para mostrar solo las semanas de la comisión actual
// Por ejemplo, si estamos en /cursada/c1/..., mostramos solo archivos de esa ruta
semanas = semanas.filter((semana) => {
	const commissionPath = currentPathname.split('/').slice(0, 3).join('/') // ej: /cursada/c1
	return semana.url.startsWith(commissionPath)
})

// Filtramos para mostrar solo las semanas que tengan el atributo mostrar en true
// Por compatibilidad con archivos viejos, si no existe el atributo también lo mostramos
semanas = semanas.reverse().filter((semana) => {
	return semana.frontmatter.mostrar !== false
})

const { title } = Astro.props
---

<DefaultLayout title={title}>
	<div class="flex">
		<aside
			class="sticky left-0 top-0 h-screen w-48 rounded-lg bg-gradient-to-t from-slate-200 to-[--background] dark:from-zinc-800 dark:to-[--background]">
			<AsideMenu
				title="Semanas"
				data={semanas}
			/>
		</aside>
		<div class="sm:m-auto">
			<slot />
		</div>
	</div>
</DefaultLayout>

<style>
	@media (max-width: 775px) {
		aside {
			display: none;
		}
	}
	@media (max-width: 1200px) {
		aside {
			min-width: 8rem;
		}
	}
</style>
