---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { PATH_C1, PATH_C2, PATH_C3 } from '@/paths.js'
---

<DefaultLayout
	title="Cursada - Estrategias de Persistencia"
	description="Universidad Nacional de Hurlingham, cursada / semana de Programación con Estrategias de Persistencia"
	author="Estrategias de Persistencia">
	<section class="my-12">
		<div class="space-content container text-center">
			<h1>Selecciona tu Comisión</h1>
			<div class="selection-grid mt-10">
				<a
					href={PATH_C1}
					class="selection-card">
					<h2>C1</h2>
					<p>Turno Noche - Prof. Gerardo Gonzalez Tulian</p>
				</a>
				<a
					href={PATH_C2}
					class="selection-card">
					<h2>C2</h2>
					<p>Turno Noche - Prof. Lucas Figarola</p>
				</a>
				<a
					href={PATH_C3}
					class="selection-card">
					<h2>C3</h2>
					<p>Turno Noche - Prof. Lucas Figarola</p>
				</a>
			</div>
		</div>
	</section>
</DefaultLayout>

<style lang="scss">
	.selection-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;

		@media (min-width: 768px) {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.selection-card {
		display: block;
		padding: 2rem;
		background-color: var(--neutral-200);
		border: 2px solid var(--action-color);
		border-radius: var(--radius-large);
		text-decoration: none;
		transition: transform 0.2s ease, background-color 0.2s ease;

		h2 {
			margin-bottom: 0.5rem;
			color: var(--action-color);
		}

		p {
			color: var(--font-color);
		}

		&:hover {
			transform: translateY(-5px);
			background-color: var(--primary-100);
		}
	}

	:global(.darkmode) .selection-card {
		background-color: var(--neutral-900);
		&:hover {
			background-color: var(--neutral-800);
		}
	}
</style>
