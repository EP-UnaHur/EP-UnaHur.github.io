---
import CardSemana from '@components/CardSemana.astro'
import DefaultLayout from '@layouts/DefaultLayout.astro'

const semanas = await Astro.glob('./*.md') //Para buscar todos los archivos .md en la carpeta
---

<DefaultLayout
	title="Cursada - Estrategias de Persistencia"
	description="Universidad Nacional de Hurlingham, cursada / semana de Programación con Estrategias de Persistencia"
	author="Estrategias de Persistencia">
	<section class="my-12">
		<div class="space-content container">
			<h1>Cursada</h1>
			<ul class="m-auto">
				{
					semanas
						.reverse()
						.filter((semana) => {
							return semana.frontmatter.mostrar === true
						})
						.map((semana) => (
							<li>
								<CardSemana
									frontmatter={semana.frontmatter}
									url={semana.url}
								/>
							</li>
						))
				}
			</ul>
		</div>
	</section>
</DefaultLayout>

<style lang="scss">
	ul {
		display: grid;
		grid-template-columns: 1fr;
		grid-gap: 4rem;

		@media (min-width: 550px) {
			grid-template-columns: repeat(2, 1fr);
			grid-gap: 2rem;
		}

		@media (min-width: 950px) {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
